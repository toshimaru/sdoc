<ul>
  <% tree.each do |class_name, path, _, nested_tree| %>
    <li>
      <a href="<%= "#{rel_prefix}/#{path}" %>"><%= class_name %></a>
      <% if nested_tree.any? %>
        <%= include_template '_navigation_tree.html.erb', { tree: nested_tree, rel_prefix: rel_prefix } %>
      <% end %>
    </li>
  <% end %>
</ul>
